From cc0d88987a610ba73a7938167624b294804cfaa2 Mon Sep 17 00:00:00 2001
From: BSP Porter <port@example.com>
Date: Sat, 14 Mar 2026 18:33:03 +0800
Subject: [PATCH 06/10] nvram: auto-detect nvmem path for Jammy/Noble
 compatibility

Replace hardcoded nvmem path with runtime detection. On Noble (6.8)
the path is 3-00501, on Jammy (5.15) it's 3-00500. Try both paths
and fall back to ~/.config/ if EEPROM is not available.

This eliminates the need for sed patching during install.
---
 Python_Module/MangDang/mini_pupper/nvram.py | 29 ++++++++++++++++++---
 1 file changed, 26 insertions(+), 3 deletions(-)

diff --git a/Python_Module/MangDang/mini_pupper/nvram.py b/Python_Module/MangDang/mini_pupper/nvram.py
index 3a77223..4ed5430 100644
--- a/Python_Module/MangDang/mini_pupper/nvram.py
+++ b/Python_Module/MangDang/mini_pupper/nvram.py
@@ -1,13 +1,36 @@
+import os
 import pickle
 
-ServoCalibrationFilePath = '/sys/bus/nvmem/devices/3-00500/nvmem'
+
+def _detect_nvmem_path():
+    patterns = [
+        '/sys/bus/nvmem/devices/3-00501/nvmem',  # Noble default
+        '/sys/bus/nvmem/devices/3-00500/nvmem',  # Jammy fallback
+    ]
+    for path in patterns:
+        if os.path.exists(path):
+            return path
+    return None
+
+
+_NVMEM_PATH = _detect_nvmem_path()
+_FALLBACK_PATH = os.path.expanduser('~/.config/mini_pupper_bsp/servo_calibration.pkl')
+
+
+def _active_path():
+    if _NVMEM_PATH is not None and os.path.exists(_NVMEM_PATH):
+        return _NVMEM_PATH
+    return _FALLBACK_PATH
 
 
 def write(data):
-    with open(ServoCalibrationFilePath, 'wb') as fd:
+    active_path = _active_path()
+    os.makedirs(os.path.dirname(active_path), exist_ok=True)
+    with open(active_path, 'wb') as fd:
         pickle.dump(data, fd, protocol=pickle.HIGHEST_PROTOCOL)
 
 
 def read():
-    with open(ServoCalibrationFilePath, 'rb') as fd:
+    active_path = _active_path()
+    with open(active_path, 'rb') as fd:
         return pickle.load(fd)
-- 
