From 6c0c35a26d22db6fd818120497f8ae311fe23c50 Mon Sep 17 00:00:00 2001
From: BSP Porter <port@example.com>
Date: Sat, 14 Mar 2026 18:32:43 +0800
Subject: [PATCH 01/10] kernel: add kernel 6.8 compatibility to

Add version-guarded probe/remove functions for kernel 6.3+ API changes:
- probe: remove const struct i2c_device_id *id parameter, get it via
  i2c_client_get_device_id() on 6.3+
- remove: change return type from int to void on 6.3+

Add GPIO base offset detection to battery_monitor script for Noble/6.8
where GPIO numbering is base 512 instead of 0.
---
 2 files changed, 19 insertions(+), 2 deletions(-)

index 5c5f2ba..cee7013 100755
@@ -4,13 +4,17 @@
 # Copyright (c) 2021, MangDang Technology Co., Limited
 #
 
+# Detect GPIO base offset (512 on Noble/6.8, 0 on Jammy/5.15)
+GPIO_BASE=0
+[ -d /sys/class/gpio/gpiochip512 ] && GPIO_BASE=512
+
 #Power monitor
 while true
 do
 	if [ $current_voltage -le 6500 ]; then
-		echo 0 > /sys/class/gpio/gpio25/value
-		echo 0 > /sys/class/gpio/gpio21/value
+		echo 0 > /sys/class/gpio/gpio$((GPIO_BASE + 25))/value
+		echo 0 > /sys/class/gpio/gpio$((GPIO_BASE + 21))/value
 		# install scrip will replace BASEDIR
 		mpg123 BASEDIR/Audio/low_power.mp3
 		/usr/bin/display_low_battery.py 
index fec4532..0bbc233 100644
@@ -26,6 +26,7 @@
 #include <linux/pm.h>
 #include <linux/regmap.h>
 #include <linux/slab.h>
+#include <linux/version.h>
 
 
 };
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 3, 0)
+{
+	const struct i2c_device_id *id = i2c_client_get_device_id(client);
+#else
 			  const struct i2c_device_id *id)
 {
+#endif
 	struct i2c_adapter *adapter = to_i2c_adapter(client->dev.parent);
 	struct power_supply_config psy_cfg = {};
@@ -1137,7 +1144,11 @@ err_attr:
 	return ret;
 }
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 3, 0)
+#else
+#endif
 {
 
 	sysfs_remove_group(&priv->dev->kobj, priv->attr_grp);
 	power_supply_unregister(priv->battery);
 
+#if LINUX_VERSION_CODE < KERNEL_VERSION(6, 3, 0)
 	return 0;
+#endif
 }
 
 #ifdef CONFIG_PM_SLEEP
